# ── Configuración común ──────────────────────────────────────────────────────
SYMBOL=BTC                     # BTC | SOL | ETH
CAPITAL_INICIAL=100.0          # Capital inicial en USD

# ── Solo para SIMULACIÓN ─────────────────────────────────────────────────────
# No requiere credenciales. Ejecutar: python app.py
ENTRY_USD=3.0                  # USD fijo por lado (simulación)

# ── Solo para PRODUCCIÓN ─────────────────────────────────────────────────────
POLYMARKET_KEY=tu_clave_privada_hex_sin_0x
PROXY_ADDRESS=tu_proxy_address_de_polymarket
